{
  "name": "leasebase-auth-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev:inspect-user": "tsx scripts/dev-user.ts inspect",
    "dev:delete-user": "tsx scripts/dev-user.ts delete",
    "dev:repair-user": "tsx scripts/dev-user.ts repair",
    "dev:list-users": "tsx scripts/dev-user.ts list"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@leasebase/service-common": "^2.0.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
